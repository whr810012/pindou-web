{
  "name": "web-pindou",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:packages": "npm run build --prefix packages/app-shared",
    "dev": "vite",
    "dev:ai": "tsx server/ai-preprocess/dev-server.ts",
    "dev:xhs": "tsx server/xhs-parse/dev-server.ts",
    "build": "npm run build:packages && node scripts/generate-og-png.mjs && node scripts/generate-gallery-pages.mjs && node scripts/generate-seo.mjs --pre && vite build && node scripts/generate-seo.mjs --post && node scripts/prerender.mjs",
    "preview": "vite preview",
    "generate:palette": "node scripts/generate-palette.mjs",
    "generate:landing-compare": "node scripts/generate-landing-compare.mjs",
    "generate:gallery-projects": "npm run build:packages && node scripts/generate-gallery-projects.mjs",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:ai": "vitest run server/ai-preprocess",
    "test:xhs": "vitest run server/xhs-parse"
  },
  "dependencies": {
    "@pindou/app-shared": "file:./packages/app-shared",
    "@volcengine/openapi": "^1.36.2",
    "@wangdandan810012/bead-core": "^0.2.0",
    "jspdf": "^4.2.1",
    "pinia": "^2.1.7",
    "three": "^0.184.0",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@netlify/functions": "^2.8.2",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/tsconfig": "^0.5.1",
    "playwright": "^1.61.0",
    "sass": "^1.77.8",
    "tsx": "^4.19.2",
    "typescript": "^5.4.5",
    "vite": "^5.2.8",
    "vitest": "^1.6.0",
    "vue-tsc": "^2.0.6"
  }
}
