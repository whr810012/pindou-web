{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@pindou/app-shared": ["./packages/app-shared/src/index.ts"],
      "@pindou/app-shared/*": ["./packages/app-shared/src/*"]
    },
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "types": ["vite/client"]
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "env.d.ts"]
}
