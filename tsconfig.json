{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@pindou/app-shared": ["./packages/app-shared/src/index.ts"],
      "@pindou/app-shared/*": ["./packages/app-shared/src/*"],
      "@pindou/bead-core": ["./packages/bead-core/src/index.ts"],
      "@pindou/bead-core/*": ["./packages/bead-core/src/*"]
    },
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "types": ["vite/client"]
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "env.d.ts"]
}
